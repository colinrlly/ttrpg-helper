{
  "name": "ttrpg-helper",
  "version": "0.0.1",
  "description": "A local-first desktop assistant for tabletop RPG dungeon masters",
  "main": "./out/main/index.js",
  "author": "Colin Reilly",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^31.7.0",
    "electron-vite": "^2.3.0",
    "playwright": "^1.48.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  }
}
